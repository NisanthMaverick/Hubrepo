# Master Bot Configuration
TELEGRAM_BOT_TOKEN=your_master_bot_token_here

# Database Configuration (Optional for local testing, fallback to local JSON file)
# Required for Render persistence!
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/masterbot

# Directory where child bots will be cloned and run
BOTS_DIR=./bots

# Port for optional Webhook routing (if needed, otherwise child bots run in polling)
PORT=10000
